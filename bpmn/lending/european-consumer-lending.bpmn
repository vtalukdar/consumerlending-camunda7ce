<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="Camunda Modeler"
             exporterVersion="5.10.0">

  <process id="EuropeanConsumerLending" name="European Consumer Lending Process" isExecutable="true" camunda:historyTimeToLive="30">

    <!-- Start Event -->
    <startEvent id="StartEvent_1" name="Loan Application Started">
      <outgoing>Flow_1</outgoing>
    </startEvent>

    <!-- Customer Information Form -->
    <userTask id="CustomerInformationTask" name="Enter Customer Information" camunda:formKey="embedded:app:forms/customer-info.html" camunda:assignee="demo">
      <documentation>Capture customer details: Full Name, Email, Phone, Income, Marital Status, Number of Children</documentation>
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </userTask>

    <!-- AML/KYC Check (External Task) -->
    <serviceTask id="AmlKycTask" name="AML &amp; KYC Verification" camunda:type="external" camunda:topic="aml_kyc_check">
      <documentation>Perform Anti-Money Laundering and Know Your Customer verification</documentation>
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </serviceTask>

    <!-- AML/KYC Decision Gateway -->
    <exclusiveGateway id="Gateway_AmlKyc" name="AML/KYC Passed?">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_AmlPass</outgoing>
      <outgoing>Flow_AmlFail</outgoing>
    </exclusiveGateway>

    <!-- Rejection Task -->
    <userTask id="RejectionTask" name="Application Rejected - AML/KYC Failed">
      <incoming>Flow_AmlFail</incoming>
      <outgoing>Flow_ToRejectEnd</outgoing>
    </userTask>

    <endEvent id="EndEvent_Rejected" name="Application Rejected">
      <incoming>Flow_ToRejectEnd</incoming>
    </endEvent>

    <!-- Fraud Detection (External Task) -->
    <serviceTask id="FraudCheckTask" name="Fraud Detection Analysis" camunda:type="external" camunda:topic="fraud_check">
      <documentation>Analyze customer and loan application for fraud indicators</documentation>
      <incoming>Flow_AmlPass</incoming>
      <outgoing>Flow_4</outgoing>
    </serviceTask>

    <!-- Fraud Decision Gateway -->
    <exclusiveGateway id="Gateway_Fraud" name="Fraud Risk Acceptable?">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_FraudAccept</outgoing>
      <outgoing>Flow_FraudReject</outgoing>
    </exclusiveGateway>

    <!-- Fraud Rejection -->
    <userTask id="FraudRejectionTask" name="Application Rejected - Fraud Risk">
      <incoming>Flow_FraudReject</incoming>
      <outgoing>Flow_ToFraudRejectEnd</outgoing>
    </userTask>

    <endEvent id="EndEvent_FraudRejected" name="Application Rejected (Fraud)">
      <incoming>Flow_ToFraudRejectEnd</incoming>
    </endEvent>

    <!-- Credit Risk Assessment (DMN) -->
    <serviceTask id="CreditRiskTask" name="Evaluate Credit Risk &amp; Calculate Propositions" camunda:type="external" camunda:topic="credit_risk_assessment">
      <documentation>Use DMN to evaluate credit risk based on income, debt-to-income ratio, and other factors. Generate loan propositions.</documentation>
      <incoming>Flow_FraudAccept</incoming>
      <outgoing>Flow_5</outgoing>
    </serviceTask>

    <!-- Credit Decision Gateway -->
    <exclusiveGateway id="Gateway_CreditRisk" name="Credit Risk Acceptable?">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_CreditPass</outgoing>
      <outgoing>Flow_CreditFail</outgoing>
    </exclusiveGateway>

    <!-- Credit Rejection -->
    <userTask id="CreditRejectionTask" name="Application Rejected - Poor Credit Risk">
      <incoming>Flow_CreditFail</incoming>
      <outgoing>Flow_ToCreditRejectEnd</outgoing>
    </userTask>

    <endEvent id="EndEvent_CreditRejected" name="Application Rejected (Credit)">
      <incoming>Flow_ToCreditRejectEnd</incoming>
    </endEvent>

    <!-- Display Loan Propositions -->
    <userTask id="LoanPropositionsTask" name="Review Loan Propositions" camunda:formKey="embedded:app:forms/loan-propositions.html" camunda:assignee="demo">
      <documentation>Display available loan propositions with different terms, rates, and amounts</documentation>
      <incoming>Flow_CreditPass</incoming>
      <outgoing>Flow_6</outgoing>
    </userTask>

    <!-- Select Loan Proposition -->
    <userTask id="SelectPropositionTask" name="Select Loan Proposition" camunda:formKey="embedded:app:forms/select-proposition.html" camunda:assignee="demo">
      <documentation>Customer selects their preferred loan proposition from available options</documentation>
      <incoming>Flow_6</incoming>
      <outgoing>Flow_7</outgoing>
    </userTask>

    <!-- Generate Loan Contract -->
    <serviceTask id="GenerateContractTask" name="Generate Loan Contract" camunda:type="external" camunda:topic="generate_contract">
      <documentation>Generate personalized loan contract with selected terms and conditions</documentation>
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </serviceTask>

    <!-- Contract Review &amp; Signature -->
    <userTask id="ContractSignatureTask" name="Review &amp; Sign Loan Contract" camunda:formKey="embedded:app:forms/contract-signature.html" camunda:assignee="demo">
      <documentation>Customer reviews and digitally signs the loan contract</documentation>
      <incoming>Flow_8</incoming>
      <outgoing>Flow_9</outgoing>
    </userTask>

    <!-- Contract Signature Decision -->
    <exclusiveGateway id="Gateway_Signature" name="Contract Signed?">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_Signed</outgoing>
      <outgoing>Flow_Unsigned</outgoing>
    </exclusiveGateway>

    <!-- Contract Not Signed -->
    <userTask id="SignatureDeclinedTask" name="Application Declined - Contract Not Signed">
      <incoming>Flow_Unsigned</incoming>
      <outgoing>Flow_ToSignatureRejectEnd</outgoing>
    </userTask>

    <endEvent id="EndEvent_SignatureDeclined" name="Application Declined">
      <incoming>Flow_ToSignatureRejectEnd</incoming>
    </endEvent>

    <!-- Fund Disbursement -->
    <serviceTask id="FundDisbursementTask" name="Process Fund Disbursement" camunda:type="external" camunda:topic="fund_disbursement">
      <documentation>Transfer approved loan amount to customer's bank account</documentation>
      <incoming>Flow_Signed</incoming>
      <outgoing>Flow_10</outgoing>
    </serviceTask>

    <!-- Success End Event -->
    <endEvent id="EndEvent_Success" name="Loan Application Approved &amp; Funded">
      <incoming>Flow_10</incoming>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="CustomerInformationTask" />
    <sequenceFlow id="Flow_2" sourceRef="CustomerInformationTask" targetRef="AmlKycTask" />
    <sequenceFlow id="Flow_3" sourceRef="AmlKycTask" targetRef="Gateway_AmlKyc" />
    <sequenceFlow id="Flow_AmlPass" name="Pass" sourceRef="Gateway_AmlKyc" targetRef="FraudCheckTask">
      <conditionExpression xsi:type="tFormalExpression">${amlKycPassed == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AmlFail" name="Fail" sourceRef="Gateway_AmlKyc" targetRef="RejectionTask">
      <conditionExpression xsi:type="tFormalExpression">${amlKycPassed == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ToRejectEnd" sourceRef="RejectionTask" targetRef="EndEvent_Rejected" />
    <sequenceFlow id="Flow_4" sourceRef="FraudCheckTask" targetRef="Gateway_Fraud" />
    <sequenceFlow id="Flow_FraudAccept" name="Acceptable" sourceRef="Gateway_Fraud" targetRef="CreditRiskTask">
      <conditionExpression xsi:type="tFormalExpression">${fraudRiskAcceptable == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_FraudReject" name="Unacceptable" sourceRef="Gateway_Fraud" targetRef="FraudRejectionTask">
      <conditionExpression xsi:type="tFormalExpression">${fraudRiskAcceptable == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ToFraudRejectEnd" sourceRef="FraudRejectionTask" targetRef="EndEvent_FraudRejected" />
    <sequenceFlow id="Flow_5" sourceRef="CreditRiskTask" targetRef="Gateway_CreditRisk" />
    <sequenceFlow id="Flow_CreditPass" name="Acceptable" sourceRef="Gateway_CreditRisk" targetRef="LoanPropositionsTask">
      <conditionExpression xsi:type="tFormalExpression">${creditRiskAcceptable == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_CreditFail" name="Poor Risk" sourceRef="Gateway_CreditRisk" targetRef="CreditRejectionTask">
      <conditionExpression xsi:type="tFormalExpression">${creditRiskAcceptable == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ToCreditRejectEnd" sourceRef="CreditRejectionTask" targetRef="EndEvent_CreditRejected" />
    <sequenceFlow id="Flow_6" sourceRef="LoanPropositionsTask" targetRef="SelectPropositionTask" />
    <sequenceFlow id="Flow_7" sourceRef="SelectPropositionTask" targetRef="GenerateContractTask" />
    <sequenceFlow id="Flow_8" sourceRef="GenerateContractTask" targetRef="ContractSignatureTask" />
    <sequenceFlow id="Flow_9" sourceRef="ContractSignatureTask" targetRef="Gateway_Signature" />
    <sequenceFlow id="Flow_Signed" name="Yes" sourceRef="Gateway_Signature" targetRef="FundDisbursementTask">
      <conditionExpression xsi:type="tFormalExpression">${contractSigned == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Unsigned" name="No" sourceRef="Gateway_Signature" targetRef="SignatureDeclinedTask">
      <conditionExpression xsi:type="tFormalExpression">${contractSigned == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_ToSignatureRejectEnd" sourceRef="SignatureDeclinedTask" targetRef="EndEvent_SignatureDeclined" />
    <sequenceFlow id="Flow_10" sourceRef="FundDisbursementTask" targetRef="EndEvent_Success" />

  </process>

  <!-- Diagram Information -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="EuropeanConsumerLending">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="100" y="220" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="75" y="260" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CustomerInformationTask_di" bpmnElement="CustomerInformationTask">
        <omgdc:Bounds x="200" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="208" y="220" width="84" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AmlKycTask_di" bpmnElement="AmlKycTask">
        <omgdc:Bounds x="380" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="389" y="230" width="82" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AmlKyc_di" bpmnElement="Gateway_AmlKyc">
        <omgdc:Bounds x="550" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="540" y="270" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RejectionTask_di" bpmnElement="RejectionTask">
        <omgdc:Bounds x="700" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="710" y="100" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <omgdc:Bounds x="872" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="858" y="143" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FraudCheckTask_di" bpmnElement="FraudCheckTask">
        <omgdc:Bounds x="700" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="709" y="230" width="82" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Fraud_di" bpmnElement="Gateway_Fraud">
        <omgdc:Bounds x="870" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="850" y="270" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FraudRejectionTask_di" bpmnElement="FraudRejectionTask">
        <omgdc:Bounds x="1020" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1030" y="100" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_FraudRejected_di" bpmnElement="EndEvent_FraudRejected">
        <omgdc:Bounds x="1192" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1178" y="143" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CreditRiskTask_di" bpmnElement="CreditRiskTask">
        <omgdc:Bounds x="1020" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1030" y="220" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CreditRisk_di" bpmnElement="Gateway_CreditRisk">
        <omgdc:Bounds x="1190" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1170" y="270" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CreditRejectionTask_di" bpmnElement="CreditRejectionTask">
        <omgdc:Bounds x="1340" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1350" y="100" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_CreditRejected_di" bpmnElement="EndEvent_CreditRejected">
        <omgdc:Bounds x="1512" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1498" y="143" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LoanPropositionsTask_di" bpmnElement="LoanPropositionsTask">
        <omgdc:Bounds x="1340" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1350" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SelectPropositionTask_di" bpmnElement="SelectPropositionTask">
        <omgdc:Bounds x="1540" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1550" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GenerateContractTask_di" bpmnElement="GenerateContractTask">
        <omgdc:Bounds x="1740" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1750" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ContractSignatureTask_di" bpmnElement="ContractSignatureTask">
        <omgdc:Bounds x="1940" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1950" y="220" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Signature_di" bpmnElement="Gateway_Signature">
        <omgdc:Bounds x="2110" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2100" y="270" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SignatureDeclinedTask_di" bpmnElement="SignatureDeclinedTask">
        <omgdc:Bounds x="2260" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2270" y="100" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SignatureDeclined_di" bpmnElement="EndEvent_SignatureDeclined">
        <omgdc:Bounds x="2432" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2418" y="143" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FundDisbursementTask_di" bpmnElement="FundDisbursementTask">
        <omgdc:Bounds x="2260" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2270" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Success_di" bpmnElement="EndEvent_Success">
        <omgdc:Bounds x="2432" y="220" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2414" y="260" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Edges -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <omgdi:waypoint x="136" y="238" />
        <omgdi:waypoint x="200" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <omgdi:waypoint x="300" y="238" />
        <omgdi:waypoint x="380" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <omgdi:waypoint x="480" y="238" />
        <omgdi:waypoint x="550" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AmlPass_di" bpmnElement="Flow_AmlPass">
        <omgdi:waypoint x="600" y="238" />
        <omgdi:waypoint x="700" y="238" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="641" y="220" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AmlFail_di" bpmnElement="Flow_AmlFail">
        <omgdi:waypoint x="575" y="215" />
        <omgdi:waypoint x="575" y="120" />
        <omgdi:waypoint x="700" y="120" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="580" y="163" width="14" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToRejectEnd_di" bpmnElement="Flow_ToRejectEnd">
        <omgdi:waypoint x="800" y="120" />
        <omgdi:waypoint x="872" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <omgdi:waypoint x="800" y="238" />
        <omgdi:waypoint x="870" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FraudAccept_di" bpmnElement="Flow_FraudAccept">
        <omgdi:waypoint x="920" y="238" />
        <omgdi:waypoint x="1020" y="238" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="960" y="220" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FraudReject_di" bpmnElement="Flow_FraudReject">
        <omgdi:waypoint x="895" y="215" />
        <omgdi:waypoint x="895" y="120" />
        <omgdi:waypoint x="1020" y="120" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="900" y="163" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToFraudRejectEnd_di" bpmnElement="Flow_ToFraudRejectEnd">
        <omgdi:waypoint x="1120" y="120" />
        <omgdi:waypoint x="1192" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <omgdi:waypoint x="1120" y="238" />
        <omgdi:waypoint x="1190" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CreditPass_di" bpmnElement="Flow_CreditPass">
        <omgdi:waypoint x="1240" y="238" />
        <omgdi:waypoint x="1340" y="238" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1280" y="220" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CreditFail_di" bpmnElement="Flow_CreditFail">
        <omgdi:waypoint x="1215" y="215" />
        <omgdi:waypoint x="1215" y="120" />
        <omgdi:waypoint x="1340" y="120" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1220" y="163" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCreditRejectEnd_di" bpmnElement="Flow_ToCreditRejectEnd">
        <omgdi:waypoint x="1440" y="120" />
        <omgdi:waypoint x="1512" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <omgdi:waypoint x="1440" y="238" />
        <omgdi:waypoint x="1540" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <omgdi:waypoint x="1640" y="238" />
        <omgdi:waypoint x="1740" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <omgdi:waypoint x="1840" y="238" />
        <omgdi:waypoint x="1940" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <omgdi:waypoint x="2040" y="238" />
        <omgdi:waypoint x="2110" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Signed_di" bpmnElement="Flow_Signed">
        <omgdi:waypoint x="2160" y="238" />
        <omgdi:waypoint x="2260" y="238" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2203" y="220" width="14" height="14" />
        </bpmndi:BPMNLabel>
